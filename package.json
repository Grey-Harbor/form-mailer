{
  "name": "@greyharbor/form-mailer",
  "version": "0.1.6",
  "type": "module",
  "description": "Lightweight form-to-email delivery for embeddable apps and serverless handlers.",
  "repository": {
    "type": "git",
    "url": "git@github.com:Grey-Harbor/form-mailer.git"
  },
  "bugs": {
    "url": "https://github.com/Grey-Harbor/form-mailer/issues"
  },
  "homepage": "https://www.greyharborsoftware.com",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "ci": "npm run check && npm test",
    "pack:check": "npm pack --dry-run",
    "site:build": "npm --prefix site run build",
    "site:preview": "npm --prefix site run preview",
    "preview": "npm --prefix site run preview",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "keywords": [
    "smtp",
    "email",
    "forms",
    "serverless",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}
