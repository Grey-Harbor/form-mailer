{
  "name": "form-mailer",
  "version": "0.1.0",
  "type": "module",
  "description": "Lightweight form-to-email delivery for Node.js apps and serverless handlers.",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "PLAN.md"
